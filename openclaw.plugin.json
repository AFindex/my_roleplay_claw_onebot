{
  "id": "my-claw-onebot",
  "name": "MyClaw OneBot",
  "version": "0.1.0",
  "description": "Minimal OneBot v11 protocol channel plugin",
  "author": "OpenAI Codex",
  "channels": [
    "onebot"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "provider": {
        "type": "string",
        "enum": [
          "generic",
          "napcat"
        ],
        "default": "generic",
        "description": "OneBot 后端提供方。默认按标准 OneBot 兼容实现处理；只有 napcat 才启用 NapCat 私有扩展。"
      },
      "type": {
        "type": "string",
        "enum": [
          "forward-websocket",
          "backward-websocket"
        ],
        "description": "连接类型：正向或反向 WebSocket"
      },
      "host": {
        "type": "string",
        "description": "OneBot 主机地址"
      },
      "port": {
        "type": "number",
        "description": "OneBot 端口"
      },
      "accessToken": {
        "type": "string",
        "description": "访问令牌（可选）"
      },
      "path": {
        "type": "string",
        "description": "WebSocket 路径，默认 /onebot/v11/ws"
      },
      "requireMention": {
        "type": "boolean",
        "default": true,
        "description": "群聊是否必须 @ 机器人才回复"
      },
      "renderMarkdownToPlain": {
        "type": "boolean",
        "default": true,
        "description": "是否将机器人回复中的 Markdown 渲染为纯文本"
      },
      "groupIncrease": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false
          },
          "message": {
            "type": "string",
            "description": "欢迎语模板，支持 {name} / {groupName} / {userId} / {groupId} / {avatarUrl}"
          }
        }
      },
      "requests": {
        "type": "object",
        "description": "好友/加群请求处理策略。默认全部只记录，不自动通过。",
        "properties": {
          "autoApproveFriend": {
            "type": "boolean",
            "default": false,
            "description": "是否自动通过好友申请"
          },
          "autoApproveGroupAdd": {
            "type": "boolean",
            "default": false,
            "description": "是否自动通过加群申请"
          },
          "autoApproveGroupInvite": {
            "type": "boolean",
            "default": false,
            "description": "是否自动通过被邀请入群"
          }
        }
      },
      "groupSummary": {
        "type": "object",
        "description": "群聊总结相关配置（当前主要用于预留 AI 总结能力参数）",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "description": "是否启用群总结配置"
          },
          "method": {
            "type": "string",
            "enum": [
              "recent-messages",
              "since-last-reply",
              "focused-keywords"
            ],
            "default": "recent-messages",
            "description": "默认总结方式"
          },
          "recentMessages": {
            "type": "number",
            "default": 80,
            "description": "参与总结的最近消息条数"
          },
          "contextCharLimit": {
            "type": "number",
            "default": 6000,
            "description": "参与总结的上下文最大字符数"
          },
          "focusKeywords": {
            "type": "array",
            "items": { "type": "string" },
            "description": "focused-keywords 模式下的关注关键词"
          },
          "ai": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "baseUrl": {
                "type": "string",
                "default": "https://api.moonshot.cn/v1"
              },
              "apiKey": {
                "type": "string",
                "description": "Moonshot API Key"
              },
              "model": {
                "type": "string",
                "default": "kimi-k2.5",
                "description": "默认群总结模型，推荐非 thinking 版本"
              },
              "timeoutMs": {
                "type": "number",
                "default": 30000
              },
              "maxTokens": {
                "type": "number",
                "default": 1024
              },
              "temperature": {
                "type": "number",
                "default": 0.3
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "provider": {
      "label": "Provider",
      "placeholder": "generic"
    },
    "accessToken": {
      "label": "Access Token",
      "sensitive": true
    },
    "host": {
      "label": "主机地址",
      "placeholder": "127.0.0.1"
    },
    "port": {
      "label": "端口",
      "placeholder": "3001"
    }
  },
  "skills": [
    "skills/onebot-ops",
    "skills/onebot-emoji-style",
    "skills/onebot-emoji-actions"
  ]
}
