{
  "name": "my-claw-onebot",
  "version": "0.1.0",
  "description": "Minimal OneBot v11 channel plugin for OpenClaw",
  "license": "MIT",
  "author": "OpenAI Codex",
  "type": "module",
  "main": "./dist/index.js",
  "exports": "./dist/index.js",
  "files": [
    "dist",
    "src",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "skills/onebot-ops",
      "skills/onebot-emoji-style",
      "skills/onebot-emoji-actions"
    ],
    "channel": {
      "id": "onebot",
      "label": "OneBot",
      "selectionLabel": "OneBot (QQ/Lagrange)",
      "docsPath": "/channels/onebot",
      "blurb": "OneBot v11 protocol via WebSocket",
      "order": 85,
      "aliases": [
        "qq",
        "lagrange",
        "cqhttp"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "test:connect": "tsx scripts/test-connect.ts",
    "test:live:group": "tsx scripts/test-live-group.ts",
    "test:live:group:362611039": "tsx scripts/test-live-group.ts --group 362611039",
    "dev:link": "openclaw plugins install -l .",
    "dev:gateway": "openclaw gateway run --verbose --force",
    "dev:logs": "openclaw logs --follow",
    "dev:probe": "openclaw gateway probe",
    "dev:restart": "openclaw gateway restart"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.0",
    "ws": "^8.18.3"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "clawdbot": {
      "optional": true
    },
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/ws": "^8.5.14",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22"
  }
}
